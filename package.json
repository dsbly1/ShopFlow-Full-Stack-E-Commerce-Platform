{
  "name": "shopflow",
  "version": "1.0.0",
  "description": "Full-Stack E-Commerce Platform with PostgreSQL, Node.js/Express, and HTML/CSS/JS",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "client": "live-server client",
    "test": "jest --testPathPatterns=server/__tests__",
    "test:coverage": "jest --testPathPatterns=server/__tests__ --coverage",
    "db:migrate": "psql $DATABASE_URL -f database/schema.sql",
    "db:seed": "psql $DATABASE_URL -f database/seeds/seed.sql"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/server/__tests__/**/*.test.js"],
    "testTimeout": 10000,
    "setupFiles": ["./server/__tests__/setup.js"]
  },
  "keywords": [
    "ecommerce",
    "postgresql",
    "nodejs",
    "express"
  ],
  "author": "Damon Bly Jr.",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.1.1",
    "pg": "^8.11.0",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  }
}